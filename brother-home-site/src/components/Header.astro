<script is:inline>
	(() => {
		const KEY = 'brother-home-lang';
		const root = document.documentElement;
		const buttons = Array.from(document.querySelectorAll('.lang-btn'));

		function applyLang(lang) {
			root.setAttribute('data-lang-mode', lang);
			buttons.forEach((btn) => {
				const active = btn.getAttribute('data-set-lang') === lang;
				btn.setAttribute('aria-pressed', active ? 'true' : 'false');
				btn.classList.toggle('is-active', active);
			});
		}

		let initial = 'en';
		try {
			initial = localStorage.getItem(KEY) || 'en';
		} catch {
			initial = 'en';
		}
		applyLang(initial);

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const lang = btn.getAttribute('data-set-lang') || 'en';
				try {
					localStorage.setItem(KEY, lang);
				} catch {
					// Ignore storage errors and still apply language in-memory.
				}
				applyLang(lang);
			});
		});
	})();
</script>
