---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const productPages = {
	'kitchen-cabinets': {
		titleEn: 'Kitchen Cabinets',
		titleZh: '橱柜',
		categoryEn: 'Kitchen & Flooring',
		categoryZh: '厨房与地板',
	},
	'hardwood-laminate-flooring': {
		titleEn: 'Hardwood & Laminate Flooring',
		titleZh: '地板',
		categoryEn: 'Kitchen & Flooring',
		categoryZh: '厨房与地板',
	},
	'quartz-countertops': {
		titleEn: 'Quartz Countertops',
		titleZh: '石英石',
		categoryEn: 'Kitchen & Flooring',
		categoryZh: '厨房与地板',
	},
	'bathroom-vanities': {
		titleEn: 'Bathroom Vanities',
		titleZh: '浴室柜',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'shower-doors': {
		titleEn: 'Shower Doors',
		titleZh: '浴室门',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'shower-doors-enclosures': {
		titleEn: 'Shower Doors & Enclosures',
		titleZh: '浴室门',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'sinks-and-pulls': {
		titleEn: 'Sinks, Handles & Pulls',
		titleZh: '水盆与把手',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'sinks-basins': {
		titleEn: 'Sinks & Basins',
		titleZh: '水盆',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'cabinet-hardware-pulls': {
		titleEn: 'Cabinet Hardware & Pulls',
		titleZh: '把手',
		categoryEn: 'Bathroom & Hardware',
		categoryZh: '浴室与五金',
	},
	'custom-walk-in-closets': {
		titleEn: 'Custom Walk-in Closets',
		titleZh: '定制衣帽间',
		categoryEn: 'Custom Storage',
		categoryZh: '定制收纳',
	},
	'storage-cabinets': {
		titleEn: 'Storage Cabinets',
		titleZh: '收纳柜',
		categoryEn: 'Custom Storage',
		categoryZh: '定制收纳',
	},
	'pantry-storage': {
		titleEn: 'Pantry Storage Systems',
		titleZh: '餐厨收纳系统',
		categoryEn: 'Custom Storage',
		categoryZh: '定制收纳',
	},
} as const;

type ProductSlug = keyof typeof productPages;

export function getStaticPaths() {
	const slugs = [
		'kitchen-cabinets',
		'hardwood-laminate-flooring',
		'quartz-countertops',
		'bathroom-vanities',
		'shower-doors',
		'shower-doors-enclosures',
		'sinks-and-pulls',
		'sinks-basins',
		'cabinet-hardware-pulls',
		'custom-walk-in-closets',
		'storage-cabinets',
		'pantry-storage',
	] as const;
	return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug as ProductSlug;
const page = productPages[slug];

const products = (await getCollection('products'))
	.filter((entry) => !entry.data.draft && entry.data.category === slug)
	.sort((a, b) => (a.data.order ?? 999999) - (b.data.order ?? 999999));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${page.titleEn} (${page.titleZh}) | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 align="center" data-lang="en"><strong>{page.titleEn}</strong></h1>
			<h1 align="center" data-lang="zh"><strong>{page.titleZh}</strong></h1>

			<table border="0" cellspacing="0" cellpadding="9" width="99%" align="center">
				<tr>
					<td colspan="3" width="100%">
						<table width="100%" border="0" cellspacing="0" cellpadding="4">
							<tr>
								<td class="prodnavigation" colspan="2" align="left">
									<b>
										<p class="prodnavigation">
											<span data-lang="en"><a href="/">Home</a> » {page.categoryEn} » {page.titleEn}</span>
											<span data-lang="zh"><a href="/">首页</a> » {page.categoryZh} » {page.titleZh}</span>
										</p>
									</b>
								</td>
								<td align="right">
									<a href="mailto:BrotherHomeanaheim@outlook.com" data-lang="en">Contact</a>
									<a href="mailto:BrotherHomeanaheim@outlook.com" data-lang="zh">联系</a>
								</td>
							</tr>

							{
								products.length === 0 && (
									<tr>
										<td colspan="3" align="center" style="padding: 28px 12px;">
											<p data-lang="en"><b>No products yet.</b> Your team can add products in CMS one by one.</p>
											<p data-lang="zh"><b>当前暂无产品。</b> 您可以在 CMS 后台逐条添加产品。</p>
										</td>
									</tr>
								)
							}

							{products.map((item) => (
								<>
									<tr>
										<td width="26%" rowspan="3" align="center" valign="middle">
											{item.data.image ? (
												<a href={item.data.image} target="_blank" rel="noopener noreferrer" title="Click to view full image">
													<img
														src={item.data.image}
														border="0"
														alt={item.data.title}
														width="120"
														height="90"
													/>
												</a>
											) : (
												<img
													src="/placeholder.svg"
													border="0"
													alt={item.data.title}
													width="120"
													height="90"
												/>
											)}
										</td>
										<td width="59%">
											<p><b>{item.data.sku || item.data.title}</b></p>
										</td>
										<td width="15%" align="right"><p><b>Details</b></p></td>
									</tr>
									<tr>
										<td colspan="2">
											<p data-lang="en"><b>{item.data.title}</b></p>
											{item.data.descriptionEn && <p data-lang="en">{item.data.descriptionEn}</p>}
											{item.data.descriptionZh && <p data-lang="zh">{item.data.descriptionZh}</p>}
											{item.data.price && (
												<>
													<p data-lang="en"><b>Price:</b> {item.data.price}</p>
													<p data-lang="zh"><b>价格:</b> {item.data.price}</p>
												</>
											)}
											{item.data.dimensions && (
												<>
													<p data-lang="en"><b>Dimensions:</b> {item.data.dimensions}</p>
													<p data-lang="zh"><b>尺寸:</b> {item.data.dimensions}</p>
												</>
											)}
											{item.data.material && (
												<>
													<p data-lang="en"><b>Material:</b> {item.data.material}</p>
													<p data-lang="zh"><b>材质:</b> {item.data.material}</p>
												</>
											)}
											<p data-lang="en"><b>Status:</b> {item.data.status === 'sold' ? 'Sold' : 'Available'}</p>
											<p data-lang="zh"><b>状态:</b> {item.data.status === 'sold' ? '已售' : '可售'}</p>
										</td>
									</tr>
									<tr>
										<td width="59%" align="center" valign="middle"></td>
										<td align="right" valign="bottom"></td>
									</tr>
									<tr>
										<td colspan="3" align="center"><hr width="70%" align="center" /></td>
									</tr>
								</>
							))}
						</table>
					</td>
				</tr>
			</table>
		</main>
		<Footer />
	</body>
</html>
